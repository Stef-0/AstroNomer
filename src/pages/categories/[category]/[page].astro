---
import SiteShell from "@/components/SiteShell.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { POSTS_PER_PAGE } from "@/lib/constants";
import { getCategoryMap } from "@/lib/content";
import { buildBreadcrumbSchema, buildOrgSchema, buildWebsiteSchema } from "@/lib/seo";
import { getCanonicalUrl } from "@/lib/site";

export async function getStaticPaths() {
  const map = await getCategoryMap();
  const paths = [];

  for (const [category, posts] of map.entries()) {
    const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);

    for (let page = 2; page <= totalPages; page += 1) {
      paths.push({
        params: { category, page: String(page) }
      });
    }
  }

  return paths;
}

const category = Astro.params.category!;
const page = Number(Astro.params.page);
const posts = (await getCategoryMap()).get(category) || [];
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
const start = (page - 1) * POSTS_PER_PAGE;
const pagePosts = posts.slice(start, start + POSTS_PER_PAGE);
---

<SiteShell
  pageTitle={`Category: ${category} page ${page}`}
  description={`Posts filed under ${category}`}
  canonicalUrl={getCanonicalUrl(`/categories/${category}/${page}`)}
  currentPath={`/categories/${category}`}
  schema={[
    buildWebsiteSchema(),
    buildOrgSchema(),
    buildBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Categories", path: "/categories" },
      { name: category, path: `/categories/${category}` }
    ])
  ]}
>
  <section class="page-shell archive">
    <p class="eyebrow">Category archive</p>
    <h2>{category}</h2>
    <div class="stack">
      {pagePosts.map((post) => <PostCard post={post} />)}
    </div>
    <Pagination currentPage={page} totalPages={totalPages} basePath={`/categories/${category}`} />
  </section>
</SiteShell>

<style>
  .archive {
    padding-bottom: var(--space-16);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 4rem);
    margin-top: 0;
  }

  .stack {
    display: grid;
    gap: var(--space-4);
  }
</style>
