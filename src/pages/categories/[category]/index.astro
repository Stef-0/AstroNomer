---
import SiteShell from "@/components/SiteShell.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { POSTS_PER_PAGE } from "@/lib/constants";
import { getCategoryMap } from "@/lib/content";
import { buildBreadcrumbSchema, buildOrgSchema, buildWebsiteSchema } from "@/lib/seo";
import { getCanonicalUrl } from "@/lib/site";

export async function getStaticPaths() {
  const map = await getCategoryMap();
  return [...map.keys()].map((category) => ({
    params: { category }
  }));
}

const category = Astro.params.category!;
const posts = (await getCategoryMap()).get(category) || [];
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
const pagePosts = posts.slice(0, POSTS_PER_PAGE);
---

<SiteShell
  pageTitle={`Category: ${category}`}
  description={`Posts filed under ${category}`}
  canonicalUrl={getCanonicalUrl(`/categories/${category}`)}
  currentPath={`/categories/${category}`}
  schema={[
    buildWebsiteSchema(),
    buildOrgSchema(),
    buildBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Categories", path: "/categories" },
      { name: category, path: `/categories/${category}` }
    ])
  ]}
>
  <section class="page-shell archive">
    <p class="eyebrow">Category archive</p>
    <h2>{category}</h2>
    <div class="stack">
      {pagePosts.map((post) => <PostCard post={post} />)}
    </div>
    <Pagination currentPage={1} totalPages={totalPages} basePath={`/categories/${category}`} />
  </section>
</SiteShell>

<style>
  .archive {
    padding-bottom: var(--space-16);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 4rem);
    margin-top: 0;
  }

  .stack {
    display: grid;
    gap: var(--space-4);
  }
</style>
