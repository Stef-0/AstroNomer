---
import SiteShell from "@/components/SiteShell.astro";
import { getCategoryMap } from "@/lib/content";
import { buildBreadcrumbSchema, buildOrgSchema, buildPageSchema, buildWebsiteSchema, getPageSocialMetadata } from "@/lib/seo";
import { getCanonicalUrl, withBasePath } from "@/lib/site";

const categories = [...(await getCategoryMap()).entries()].sort((a, b) => b[1].length - a[1].length);
const social = getPageSocialMetadata();
---

<SiteShell
  pageTitle="Categories"
  description="Browse all categories."
  canonicalUrl={getCanonicalUrl("/categories")}
  currentPath="/categories"
  image={social.image}
  schema={[
    buildWebsiteSchema(),
    buildOrgSchema(),
    buildPageSchema({
      title: "Categories",
      description: "Browse all categories.",
      path: "/categories",
      type: "CollectionPage"
    }),
    buildBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Categories", path: "/categories" }
    ])
  ]}
>
  <section class="page-shell archive-shell">
    <div class="archive-heading">
      <p class="eyebrow">Taxonomy</p>
      <h2>Categories</h2>
    </div>
    <ul class="taxonomy-grid">
      {categories.map(([category, posts]) => (
        <li class="surface-card">
          <a href={withBasePath(`/categories/${category}`)}>{category}</a>
          <span>{posts.length} posts</span>
        </li>
      ))}
    </ul>
  </section>
</SiteShell>
