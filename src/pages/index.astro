---
import SiteShell from "@/components/SiteShell.astro";
import PostCard from "@/components/PostCard.astro";
import NewsletterEmbed from "@/components/NewsletterEmbed.astro";
import { SITE_DESCRIPTION, SITE_NAME } from "@/lib/constants";
import { getAuthorName, getFeaturedPosts, getPublishedPosts } from "@/lib/content";
import { buildItemListSchema, buildOrgSchema, buildPageSchema, buildWebsiteSchema, getPageSocialMetadata } from "@/lib/seo";
import { getCanonicalUrl, withBasePath } from "@/lib/site";
import instanceConfig from "../../instance.config.mjs";

const featuredPosts = await getFeaturedPosts();
const publishedPosts = await getPublishedPosts();
const leadPosts = (featuredPosts.length ? featuredPosts : publishedPosts).slice(0, 3);
const primaryLead = leadPosts[0];
const secondaryLead = leadPosts.slice(1);
const leadSlugs = new Set(leadPosts.map((post) => post.slug));
const recentPosts = publishedPosts.filter((post) => !leadSlugs.has(post.slug)).slice(0, 9);
const social = getPageSocialMetadata();
const homepageMode = instanceConfig.shell.homepage.mode;
const showLeadTagline = homepageMode === "editorial-hero";
const showFeaturedLead = homepageMode !== "posts-only";
---

<SiteShell
  pageTitle="Home"
  description={SITE_DESCRIPTION}
  canonicalUrl={getCanonicalUrl("/")}
  currentPath="/"
  image={social.image}
  schema={[
    buildWebsiteSchema(),
    buildOrgSchema(),
    buildPageSchema({
      title: SITE_NAME,
      description: SITE_DESCRIPTION,
      path: "/"
    }),
    buildItemListSchema(publishedPosts.slice(0, 5), "/")
  ]}
>
  {showFeaturedLead && primaryLead && (
    <section class="page-shell lead-package">
      {showLeadTagline && (
        <div class="archive-heading">
          <p class="eyebrow">Latest Edition</p>
          <h2>Start with the newest and strongest work</h2>
        </div>
      )}

      <p class="eyebrow lead-package__label">Featured</p>
      <div class="lead-package__grid">
        <article class="lead-feature">
          <div class="lead-feature__content">
            {primaryLead.data.featuredImage && (
              <a class="lead-feature__media" href={withBasePath(`/blog/${primaryLead.slug}`)}>
                <div class:list={["lead-feature__overlay", `lead-feature__overlay--${primaryLead.data.featuredImageText || "light"}`]}>
                  <p class="eyebrow">{primaryLead.data.categories[0] || "Article"}</p>
                  <h3>{primaryLead.data.title}</h3>
                </div>
                <img
                  src={primaryLead.data.featuredImage.src}
                  alt={primaryLead.data.featuredImageAlt || ""}
                  loading="eager"
                />
              </a>
            )}
            {!primaryLead.data.featuredImage && (
              <>
                <p class="eyebrow">{primaryLead.data.categories[0] || "Article"}</p>
                <h3>
                  <a href={withBasePath(`/blog/${primaryLead.slug}`)}>{primaryLead.data.title}</a>
                </h3>
              </>
            )}
            <p class="lead-feature__dek">{primaryLead.data.description}</p>
            <div class="lead-feature__meta">
              <span>{primaryLead.data.publishedAt.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
              <span>By {getAuthorName(primaryLead)}</span>
            </div>
          </div>
        </article>

        <div class="lead-rail">
          <div class="lead-rail__stack">
            {secondaryLead.map((post) => (
              <article class="lead-rail__item">
                <p class="eyebrow">{post.data.categories[0] || "Article"}</p>
                <h3><a href={withBasePath(`/blog/${post.slug}`)}>{post.data.title}</a></h3>
                <p>{post.data.description}</p>
                <div class="lead-rail__meta">
                  <span>{post.data.publishedAt.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
                  <span>By {getAuthorName(post)}</span>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <section class:list={["page-shell newsroom", homepageMode === "posts-only" && "newsroom--posts-only"]}>
    <div class="newsroom__main">
      {homepageMode !== "posts-only" && (
        <div class="archive-heading">
          <p class="eyebrow">Recent Posts</p>
          <h2>From the archive</h2>
        </div>
      )}
      <div class="story-stack">
        {(homepageMode === "posts-only" ? publishedPosts : recentPosts).map((post) => <PostCard post={post} />)}
      </div>
    </div>
    {homepageMode !== "posts-only" && (
      <div class="newsroom__aside">
        <NewsletterEmbed title="Newsletter desk" description="Subscribe to new issues through the instance newsletter surface." />
      </div>
    )}
  </section>
</SiteShell>

<style>
  :root {
    --home-sidebar-width: 22rem;
  }

  .lead-package {
    padding: var(--space-6) 0 var(--space-8);
  }

  .lead-package__label {
    margin: 0 0 var(--space-4);
  }

  .lead-package .archive-heading {
    border-top: 0;
    padding-top: 0;
  }

  .lead-package .archive-heading h2 {
    max-width: 20ch;
    font-size: clamp(2.8rem, 5.8vw, 5.2rem);
    line-height: 0.88;
    text-wrap: balance;
  }

  .lead-package__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(20rem, var(--home-sidebar-width));
    gap: calc(var(--space-8) + var(--space-2));
    align-items: start;
  }

  .lead-feature {
    display: grid;
    gap: var(--space-5);
  }

  .lead-feature__media {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    position: relative;
    text-decoration: none;
  }

  .lead-feature__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 260ms ease;
  }

  .lead-feature__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-6);
    z-index: 1;
  }

  .lead-feature__overlay--light {
    background:
      linear-gradient(180deg, color-mix(in srgb, black 18%, transparent) 0%, transparent 34%, color-mix(in srgb, black 48%, transparent) 100%);
  }

  .lead-feature__overlay--light .eyebrow,
  .lead-feature__overlay--light h3 {
    color: #fffaf3;
    max-width: 10ch;
  }

  .lead-feature__overlay--dark {
    background:
      linear-gradient(180deg, color-mix(in srgb, white 16%, transparent) 0%, transparent 32%, color-mix(in srgb, white 42%, transparent) 100%);
  }

  .lead-feature__overlay--dark .eyebrow,
  .lead-feature__overlay--dark h3 {
    color: var(--color-accent-strong);
    max-width: 10ch;
  }

  .lead-feature:hover .lead-feature__media img,
  .lead-feature:focus-within .lead-feature__media img {
    transform: scale(1.02);
  }

  .lead-feature__content {
    display: grid;
    gap: var(--space-3);
  }

  .lead-feature h3,
  .lead-rail h3 {
    margin: 0;
    font-family: var(--font-heading);
    line-height: 0.96;
  }

  .lead-feature h3 {
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    max-width: 14ch;
  }

  .lead-feature h3 a,
  .lead-rail h3 a {
    text-decoration: none;
  }

  .lead-feature h3 a:hover,
  .lead-feature h3 a:focus-visible,
  .lead-rail h3 a:hover,
  .lead-rail h3 a:focus-visible {
    color: color-mix(in srgb, var(--color-accent-strong) 92%, white);
  }

  .lead-feature__dek {
    margin: 0;
    max-width: 42rem;
    font-size: 1.18rem;
    line-height: 1.6;
  }

  .lead-feature__meta,
  .lead-rail__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }

  .lead-rail {
    display: grid;
    gap: var(--space-4);
  }

  .lead-rail__stack {
    display: grid;
    gap: var(--space-6);
  }

  .lead-rail__item {
    display: grid;
    gap: var(--space-3);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .lead-rail__item:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .lead-rail h3 {
    font-size: clamp(1.8rem, 3vw, 3rem);
    max-width: 10ch;
  }

  .lead-rail__item p:not(.eyebrow) {
    margin: 0;
    line-height: 1.55;
  }

  .newsroom {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, var(--home-sidebar-width));
    gap: var(--space-8);
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
    border-top: 1px solid color-mix(in srgb, var(--color-border) 92%, transparent);
  }

  .newsroom__aside {
    align-self: start;
    width: min(100%, var(--home-sidebar-width));
    justify-self: stretch;
  }

  .newsroom__aside :global(.newsletter) {
    width: 100%;
  }

  .newsroom--posts-only {
    grid-template-columns: minmax(0, 1fr);
    padding-top: var(--space-8);
    border-top: 0;
  }

  .newsroom .archive-heading {
    border-top: 0;
    padding-top: 0;
  }

  .newsroom__main :global(.post-card:first-child) {
    border-top: 0;
    padding-top: 0;
  }

  .newsroom--posts-only .story-stack > :global(article.post-card:first-of-type) {
    border-top: 0;
    padding-top: 0;
  }

  @media (max-width: 960px) {
    .lead-package__grid,
    .newsroom {
      grid-template-columns: 1fr;
    }
  }
</style>
