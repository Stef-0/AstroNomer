---
import SiteShell from "@/components/SiteShell.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { POSTS_PER_PAGE, PRIMARY_COLLECTION_LABEL } from "@/lib/constants";
import { getPublishedPosts } from "@/lib/content";
import { buildBreadcrumbSchema, buildItemListSchema, buildOrgSchema, buildPageSchema, buildWebsiteSchema, getPageSocialMetadata } from "@/lib/seo";
import { getCanonicalUrl } from "@/lib/site";
import instanceConfig from "../../../instance.config.mjs";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => ({
    params: { page: String(index + 2) }
  }));
}

const page = Number(Astro.params.page);
const posts = await getPublishedPosts();
const start = (page - 1) * POSTS_PER_PAGE;
const pagePosts = posts.slice(start, start + POSTS_PER_PAGE);
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
const social = getPageSocialMetadata();
const shellCopy = instanceConfig.shell.copy;
const archiveDescription = `Browse page ${page} of the ${PRIMARY_COLLECTION_LABEL.toLowerCase()} archive.`;
---

<SiteShell
  pageTitle={`${PRIMARY_COLLECTION_LABEL} page ${page}`}
  description={archiveDescription}
  canonicalUrl={getCanonicalUrl(`/blog/${page}`)}
  currentPath="/blog"
  image={social.image}
  schema={[
    buildWebsiteSchema(),
    buildOrgSchema(),
    buildPageSchema({
      title: `${PRIMARY_COLLECTION_LABEL} archive page ${page}`,
      description: archiveDescription,
      path: `/blog/${page}`,
      type: "CollectionPage"
    }),
    buildItemListSchema(pagePosts, `/blog/${page}`),
    buildBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: PRIMARY_COLLECTION_LABEL, path: "/blog" }
    ])
  ]}
>
  <section class="page-shell archive-shell">
    <div class="archive-heading">
      <p class="eyebrow">{shellCopy.archiveEyebrow}</p>
      <h2>{shellCopy.archiveTitle}, page {page}</h2>
    </div>
    <div class="story-stack">
      {pagePosts.map((post) => <PostCard post={post} />)}
    </div>
    <Pagination currentPage={page} totalPages={totalPages} basePath="/blog" />
  </section>
</SiteShell>

<style>
  .archive-shell :global(.post-card:first-child) {
    border-top: 0;
    padding-top: 0;
  }
</style>
