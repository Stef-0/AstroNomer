---
import SiteShell from "@/components/SiteShell.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { POSTS_PER_PAGE } from "@/lib/constants";
import { getPublishedPosts } from "@/lib/content";
import { buildBreadcrumbSchema, buildItemListSchema, buildOrgSchema, buildPageSchema, buildWebsiteSchema, getPageSocialMetadata } from "@/lib/seo";
import { getCanonicalUrl } from "@/lib/site";

const posts = await getPublishedPosts();
const firstPagePosts = posts.slice(0, POSTS_PER_PAGE);
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
const social = getPageSocialMetadata();
---

<SiteShell
  pageTitle="Blog"
  description="Browse the full post archive."
  canonicalUrl={getCanonicalUrl("/blog")}
  currentPath="/blog"
  image={social.image}
  schema={[
    buildWebsiteSchema(),
    buildOrgSchema(),
    buildPageSchema({
      title: "Blog archive",
      description: "Browse the full post archive.",
      path: "/blog",
      type: "CollectionPage"
    }),
    buildItemListSchema(firstPagePosts, "/blog"),
    buildBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Blog", path: "/blog" }
    ])
  ]}
>
  <section class="page-shell archive">
    <p class="eyebrow">Archive</p>
    <h2>All posts</h2>
    <div class="stack">
      {firstPagePosts.map((post) => <PostCard post={post} />)}
    </div>
    <Pagination currentPage={1} totalPages={totalPages} basePath="/blog" />
  </section>
</SiteShell>

<style>
  .archive {
    padding-bottom: var(--space-16);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 4rem);
    margin-top: 0;
  }

  .stack {
    display: grid;
    gap: var(--space-4);
  }
</style>
