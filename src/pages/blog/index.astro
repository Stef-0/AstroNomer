---
import SiteShell from "@/components/SiteShell.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { POSTS_PER_PAGE, PRIMARY_COLLECTION_LABEL } from "@/lib/constants";
import { getPublishedPosts } from "@/lib/content";
import { buildBreadcrumbSchema, buildItemListSchema, buildOrgSchema, buildPageSchema, buildWebsiteSchema, getPageSocialMetadata } from "@/lib/seo";
import { getCanonicalUrl } from "@/lib/site";
import instanceConfig from "../../../instance.config.mjs";

const posts = await getPublishedPosts();
const firstPagePosts = posts.slice(0, POSTS_PER_PAGE);
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
const social = getPageSocialMetadata();
const shellCopy = instanceConfig.shell.copy;
const archiveDescription = `Browse the full ${PRIMARY_COLLECTION_LABEL.toLowerCase()} archive.`;
---

<SiteShell
  pageTitle={PRIMARY_COLLECTION_LABEL}
  description={archiveDescription}
  canonicalUrl={getCanonicalUrl("/blog")}
  currentPath="/blog"
  image={social.image}
  schema={[
    buildWebsiteSchema(),
    buildOrgSchema(),
    buildPageSchema({
      title: `${PRIMARY_COLLECTION_LABEL} archive`,
      description: archiveDescription,
      path: "/blog",
      type: "CollectionPage"
    }),
    buildItemListSchema(firstPagePosts, "/blog"),
    buildBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: PRIMARY_COLLECTION_LABEL, path: "/blog" }
    ])
  ]}
>
  <section class="page-shell archive-shell">
    <div class="archive-heading">
      <p class="eyebrow">{shellCopy.archiveEyebrow}</p>
      <h2>{shellCopy.archiveTitle}</h2>
    </div>
    <div class="story-stack">
      {firstPagePosts.map((post) => <PostCard post={post} />)}
    </div>
    <Pagination currentPage={1} totalPages={totalPages} basePath="/blog" />
  </section>
</SiteShell>

<style>
  .archive-shell :global(.post-card:first-child) {
    border-top: 0;
    padding-top: 0;
  }
</style>
