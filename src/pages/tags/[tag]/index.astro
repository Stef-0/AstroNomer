---
import SiteShell from "@/components/SiteShell.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { POSTS_PER_PAGE } from "@/lib/constants";
import { getTagMap } from "@/lib/content";
import { buildBreadcrumbSchema, buildItemListSchema, buildOrgSchema, buildPageSchema, buildWebsiteSchema, getPageSocialMetadata } from "@/lib/seo";
import { getCanonicalUrl } from "@/lib/site";

export async function getStaticPaths() {
  const map = await getTagMap();
  return [...map.keys()].map((tag) => ({
    params: { tag }
  }));
}

const tag = Astro.params.tag!;
const posts = (await getTagMap()).get(tag) || [];
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
const pagePosts = posts.slice(0, POSTS_PER_PAGE);
const social = getPageSocialMetadata();
---

<SiteShell
  pageTitle={`Tag: ${tag}`}
  description={`Posts filed under ${tag}`}
  canonicalUrl={getCanonicalUrl(`/tags/${tag}`)}
  currentPath={`/tags/${tag}`}
  image={social.image}
  schema={[
    buildWebsiteSchema(),
    buildOrgSchema(),
    buildPageSchema({
      title: `Tag archive: ${tag}`,
      description: `Posts filed under ${tag}`,
      path: `/tags/${tag}`,
      type: "CollectionPage"
    }),
    buildItemListSchema(pagePosts, `/tags/${tag}`),
    buildBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Tags", path: "/tags" },
      { name: tag, path: `/tags/${tag}` }
    ])
  ]}
>
  <section class="page-shell archive-shell">
    <div class="archive-heading">
      <p class="eyebrow">Tag archive</p>
      <h2>#{tag}</h2>
    </div>
    <div class="story-stack">
      {pagePosts.map((post) => <PostCard post={post} />)}
    </div>
    <Pagination currentPage={1} totalPages={totalPages} basePath={`/tags/${tag}`} />
  </section>
</SiteShell>

<style>
  .archive-shell :global(.post-card:first-child) {
    border-top: 0;
    padding-top: 0;
  }
</style>
