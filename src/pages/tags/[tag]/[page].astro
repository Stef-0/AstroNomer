---
import SiteShell from "@/components/SiteShell.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { POSTS_PER_PAGE } from "@/lib/constants";
import { getTagMap } from "@/lib/content";
import { buildBreadcrumbSchema, buildItemListSchema, buildOrgSchema, buildPageSchema, buildWebsiteSchema, getPageSocialMetadata } from "@/lib/seo";
import { getCanonicalUrl } from "@/lib/site";

export async function getStaticPaths() {
  const map = await getTagMap();
  const paths = [];

  for (const [tag, posts] of map.entries()) {
    const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);

    for (let page = 2; page <= totalPages; page += 1) {
      paths.push({
        params: { tag, page: String(page) }
      });
    }
  }

  return paths;
}

const tag = Astro.params.tag!;
const page = Number(Astro.params.page);
const posts = (await getTagMap()).get(tag) || [];
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
const start = (page - 1) * POSTS_PER_PAGE;
const pagePosts = posts.slice(start, start + POSTS_PER_PAGE);
const social = getPageSocialMetadata();
---

<SiteShell
  pageTitle={`Tag: ${tag} page ${page}`}
  description={`Posts filed under ${tag}`}
  canonicalUrl={getCanonicalUrl(`/tags/${tag}/${page}`)}
  currentPath={`/tags/${tag}`}
  image={social.image}
  schema={[
    buildWebsiteSchema(),
    buildOrgSchema(),
    buildPageSchema({
      title: `Tag archive: ${tag} page ${page}`,
      description: `Posts filed under ${tag}`,
      path: `/tags/${tag}/${page}`,
      type: "CollectionPage"
    }),
    buildItemListSchema(pagePosts, `/tags/${tag}/${page}`),
    buildBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Tags", path: "/tags" },
      { name: tag, path: `/tags/${tag}` }
    ])
  ]}
>
  <section class="page-shell archive-shell">
    <div class="archive-heading">
      <p class="eyebrow">Tag archive</p>
      <h2>#{tag}</h2>
    </div>
    <div class="story-stack">
      {pagePosts.map((post) => <PostCard post={post} />)}
    </div>
    <Pagination currentPage={page} totalPages={totalPages} basePath={`/tags/${tag}`} />
  </section>
</SiteShell>

<style>
  .archive-shell :global(.post-card:first-child) {
    border-top: 0;
    padding-top: 0;
  }
</style>
