---
import SiteShell from "@/components/SiteShell.astro";
import NewsletterEmbed from "@/components/NewsletterEmbed.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { getAuthorName, getPostReadingStats } from "@/lib/content";
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildFaqSchema,
  buildOrgSchema,
  buildWebsiteSchema,
  getPostSocialMetadata
} from "@/lib/seo";
import { getCanonicalUrl } from "@/lib/site";
import type { PostEntry } from "@/types/content";
import type { PostTableOfContents } from "@/lib/toc";
import instanceConfig from "../../instance.config.mjs";

interface Props {
  post: PostEntry;
  toc?: PostTableOfContents;
}

const { post, toc } = Astro.props;
const canonicalUrl = getCanonicalUrl(`/blog/${post.slug}`);
const faqSchema = buildFaqSchema(post);
const social = getPostSocialMetadata(post);
const schema = [
  buildWebsiteSchema(),
  buildOrgSchema(),
  buildArticleSchema(post),
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog" },
    { name: post.data.title, path: `/blog/${post.slug}` }
  ])
];

if (faqSchema) {
  schema.push(faqSchema);
}

const stats = getPostReadingStats(post);
---

<SiteShell
  pageTitle={post.data.title}
  description={post.data.description}
  canonicalUrl={canonicalUrl}
  currentPath={`/blog/${post.slug}`}
  type="article"
  image={social.image}
  publishedTime={social.publishedTime}
  modifiedTime={social.modifiedTime}
  author={social.author}
  tags={social.tags}
  section={social.section}
  schema={schema}
>
  <article class="page-shell post">
    <header class="post-hero">
      <p class="eyebrow">{post.data.categories[0] || "Article"}</p>
      <h1>{post.data.title}</h1>
      <p class="dek">{post.data.description}</p>
      <div class="post-meta">
        <span>{post.data.publishedAt.toLocaleDateString("en-US", { dateStyle: "long" })}</span>
        <span>By {getAuthorName(post)}</span>
        <span>{Math.ceil(stats.minutes)} min read</span>
      </div>
    </header>
    <div class="post-content">
      <div class="post-body">
        <slot />
      </div>
      <div class="post-sidebar">
        {toc && <TableOfContents toc={toc} />}
        {instanceConfig.features.newsletter && (
          <NewsletterEmbed
            title="Newsletter desk"
            description="Provider activation is deferred, but this slot is ready for an instance-level newsletter integration."
          />
        )}
      </div>
    </div>
  </article>
</SiteShell>

<style>
  .post {
    width: min(100%, 74rem);
    margin: 0 auto;
    padding-bottom: var(--space-16);
  }

  .post-hero {
    padding: var(--space-12) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  h1 {
    font-family: var(--font-heading);
    margin: 0.35rem 0 0;
    font-size: clamp(3rem, 7vw, 6.3rem);
    line-height: 0.94;
    max-width: 14ch;
  }

  .dek {
    font-size: 1.35rem;
    line-height: 1.45;
    max-width: 42rem;
    margin-top: var(--space-4);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
    font-family: var(--font-display);
    font-size: 0.84rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }

  .post-meta span + span::before {
    content: "•";
    margin-right: var(--space-3);
  }

  .post-content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 20rem);
    gap: var(--space-8);
    align-items: stretch;
  }

  .post-sidebar {
    display: grid;
    gap: var(--space-5);
    align-content: start;
    align-self: stretch;
  }

  .post-body {
    width: 100%;
    max-width: var(--reading-width);
    font-size: 1.16rem;
    line-height: 1.82;
    align-self: start;
  }

  .post-body :global(p),
  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: 1.35rem;
  }

  .post-body :global(h2),
  .post-body :global(h3) {
    font-family: var(--font-heading);
    margin-top: 2.4rem;
    line-height: 1.05;
  }

  .post-body :global(h2) {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .post-body :global(blockquote) {
    margin: 2rem 0;
    padding-left: 1.2rem;
    border-left: 3px solid var(--color-border-strong);
    font-style: italic;
  }

  .post-body :global(pre),
  .post-body :global(figure) {
    margin: 2rem 0;
  }

  .post-body :global(.code-block),
  .post-body :global(.newsletter),
  .post-sidebar :global(.newsletter),
  .post-sidebar :global(.toc) {
    border-radius: var(--radius-sm);
  }

  @media (max-width: 760px) {
    .post-meta {
      gap: var(--space-2);
    }

    .post-meta span + span::before {
      margin-right: var(--space-2);
    }

    .post-content {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      gap: var(--space-4);
    }

    .post-content :global(.toc) {
      order: -1;
      position: static;
    }
  }
</style>
