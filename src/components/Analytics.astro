---
import instanceConfig from "../../instance.config.mjs";

const gaId = import.meta.env.PUBLIC_GA4_ID;
const shouldRender = instanceConfig.features.analytics === "ga4" && Boolean(gaId);
const isCookieless = instanceConfig.features.analyticsPrivacyMode === "cookieless";
---

{
  shouldRender && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script is:inline define:vars={{ gaId, isCookieless }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        const config = isCookieless
          ? {
              anonymize_ip: true,
              client_storage: 'none'
            }
          : {
              cookie_flags: 'SameSite=None;Secure'
            };
        gtag('config', gaId, config);
      </script>
    </>
  )
}
