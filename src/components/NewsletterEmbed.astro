---
import instanceConfig from "../../instance.config.mjs";
import { withBasePath } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
  headingLevel?: "h2" | "h3";
}

const {
  title = instanceConfig.newsletter.title,
  description = instanceConfig.newsletter.description,
  headingLevel = "h2"
} = Astro.props;

const Heading = headingLevel;

const newsletter = instanceConfig.newsletter;
const eyebrow = newsletter.eyebrow;

function resolveUrl(value: string) {
  return value.startsWith("/") ? withBasePath(value) : value;
}
---

<aside class="surface-card newsletter">
  <p class="eyebrow">{eyebrow}</p>
  <Heading>{title}</Heading>
  <p class="newsletter__description">{description}</p>

  {newsletter.mode === "placeholder" && newsletter.description !== description && (
    <p class="newsletter__note">{newsletter.description}</p>
  )}

  {newsletter.mode === "button" && (
    <>
      <a class="newsletter__cta" href={resolveUrl(newsletter.href)}>
        {newsletter.ctaLabel}
      </a>
      {newsletter.note && <p class="newsletter__note">{newsletter.note}</p>}
    </>
  )}

  {newsletter.mode === "form" && (
    <>
      <form
        class="newsletter__form"
        action={resolveUrl(newsletter.action)}
        method={newsletter.method}
      >
        <label class="sr-only" for="newsletter-email">Email address</label>
        <input
          id="newsletter-email"
          type="email"
          name={newsletter.emailName}
          placeholder={newsletter.emailPlaceholder}
          autocomplete="email"
          required
        />
        {newsletter.hiddenFields.map((field) => (
          <input type="hidden" name={field.name} value={field.value} />
        ))}
        <button type="submit">{newsletter.submitLabel}</button>
      </form>
      {newsletter.note && <p class="newsletter__note">{newsletter.note}</p>}
    </>
  )}

  {newsletter.mode === "embed" && (
    <>
      <div class="newsletter__frame-wrap">
        <iframe
          class="newsletter__frame"
          src={resolveUrl(newsletter.src)}
          title={title}
          loading="lazy"
          style={`min-height: ${newsletter.minHeight}px;`}
        />
      </div>
      {newsletter.note && <p class="newsletter__note">{newsletter.note}</p>}
    </>
  )}
</aside>

<style>
  .newsletter {
    padding: var(--space-6);
    background: color-mix(in srgb, var(--color-highlight) 48%, white);
    display: grid;
    gap: var(--space-4);
  }

  .newsletter :global(h2),
  .newsletter :global(h3) {
    margin: 0.25rem 0 0;
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1.05;
  }

  .newsletter__description,
  .newsletter__note {
    margin: 0;
  }

  .newsletter__cta,
  .newsletter button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.875rem;
    padding: 0.7rem 1rem;
    border: 1px solid var(--color-accent-strong);
    background: var(--color-accent-strong);
    color: var(--color-surface);
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
    cursor: pointer;
  }

  .newsletter__cta:hover,
  .newsletter__cta:focus-visible,
  .newsletter button:hover,
  .newsletter button:focus-visible {
    background: color-mix(in srgb, var(--color-accent-strong) 85%, white);
    border-color: color-mix(in srgb, var(--color-accent-strong) 85%, white);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .newsletter__form {
    display: grid;
    gap: var(--space-3);
  }

  .newsletter__form input[type="email"] {
    min-height: 2.875rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-border-strong);
    background: color-mix(in srgb, white 78%, var(--color-surface));
    color: var(--color-text);
    font: inherit;
  }

  .newsletter__frame-wrap {
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, white 82%, var(--color-surface));
  }

  .newsletter__frame {
    width: 100%;
    border: 0;
  }

  .newsletter__note {
    font-size: 0.96rem;
    line-height: 1.55;
    color: var(--color-text-soft);
  }

  .newsletter:hover,
  .newsletter:focus-within {
    background: color-mix(in srgb, var(--color-highlight) 62%, white);
    border-color: var(--color-border-strong);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
