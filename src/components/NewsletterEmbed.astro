---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Newsletter integration placeholder",
  description = "This seam is intentionally provider-neutral until a newsletter integration is selected."
} = Astro.props;
---

<aside class="surface-card newsletter">
  <p class="eyebrow">Future Module</p>
  <h2>{title}</h2>
  <p>{description}</p>
</aside>

<style>
  .newsletter {
    padding: var(--space-6);
    background: color-mix(in srgb, var(--color-highlight) 48%, white);
  }

  .newsletter h2 {
    margin: 0.25rem 0 0.75rem;
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1.05;
  }

  .newsletter:hover,
  .newsletter:focus-within {
    background: color-mix(in srgb, var(--color-highlight) 62%, white);
    border-color: var(--color-border-strong);
  }
</style>
