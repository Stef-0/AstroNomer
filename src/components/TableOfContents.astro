---
import type { PostTableOfContents } from "@/lib/toc";
interface Props {
  toc: PostTableOfContents;
}

const { toc } = Astro.props;
---

<nav class="toc surface-card" aria-label="Table of contents">
  <p class="eyebrow">Contents</p>
  <h3>{toc.title}</h3>
  <ol>
    {toc.items.map((item) => (
      <li class={`toc__item toc__item--depth-${item.depth}`}>
        <a href={`#${item.slug}`}>{item.text}</a>
      </li>
    ))}
  </ol>
</nav>

<script>
  function initTocSpy() {
    const toc = document.querySelector('.toc');
    if (!toc) return;

    const links = toc.querySelectorAll('.toc__item a');
    const slugs = Array.from(links).map(a => a.getAttribute('href')?.replace('#', '')).filter(Boolean);
    const headings = slugs.map(id => document.getElementById(id!)).filter(Boolean) as HTMLElement[];

    if (!headings.length) return;

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          links.forEach(link => {
            const item = link.closest('.toc__item');
            if (item) {
              item.classList.toggle('is-active', link.getAttribute('href') === `#${entry.target.id}`);
            }
          });
        }
      }
    }, { rootMargin: '0px 0px -75% 0px' });

    headings.forEach(h => observer.observe(h));
  }

  initTocSpy();
</script>

<style>
  .toc {
    padding: var(--space-5);
    position: sticky;
    top: var(--space-8);
    background: color-mix(in srgb, var(--color-surface) 90%, white);
  }

  .toc h3 {
    margin: 0.35rem 0 1rem;
    font-family: var(--font-heading);
    font-size: 1.6rem;
    line-height: 1.05;
  }

  .toc ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
  }

  .toc__item a {
    display: inline-block;
    text-decoration: none;
    line-height: 1.45;
    color: var(--color-text-soft);
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  .toc__item:global(.is-active) a {
    color: var(--color-accent);
    font-weight: 600;
  }

  .toc__item--depth-3,
  .toc__item--depth-4,
  .toc__item--depth-5,
  .toc__item--depth-6 {
    padding-left: var(--space-3);
  }

  .toc__item--depth-4,
  .toc__item--depth-5,
  .toc__item--depth-6 {
    padding-left: var(--space-4);
  }

  .toc__item a:hover,
  .toc__item a:focus-visible {
    color: var(--color-accent-strong);
    transform: translateX(2px);
  }
</style>
