---
import { withBasePath } from "@/lib/site";

interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;

function hrefFor(page: number) {
  return withBasePath(page === 1 ? basePath : `${basePath}/${page}`);
}
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="Pagination">
    <div class="pagination__slot pagination__slot--prev">
      {currentPage > 1 && <a href={hrefFor(currentPage - 1)}>← Previous</a>}
    </div>
    <span class="pagination__status">
      Page {currentPage} of {totalPages}
    </span>
    <div class="pagination__slot pagination__slot--next">
      {currentPage < totalPages && <a href={hrefFor(currentPage + 1)}>Next →</a>}
    </div>
  </nav>
)}

<style>
  .pagination {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-4);
    align-items: center;
    margin-top: var(--space-8);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .pagination__slot {
    display: flex;
  }

  .pagination__slot--next {
    justify-content: flex-end;
  }

  .pagination a {
    text-decoration: none;
    padding: 0.7rem 0;
    font-family: var(--font-display);
    font-size: 0.84rem;
  }

  .pagination a:hover,
  .pagination a:focus-visible {
    color: var(--color-accent-strong);
    transform: translateY(-1px);
  }

  .pagination__status {
    font-family: var(--font-display);
    font-size: 0.82rem;
    color: var(--color-text-soft);
    white-space: nowrap;
  }
</style>
