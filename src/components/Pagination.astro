---
import { withBasePath } from "@/lib/site";

interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;

function hrefFor(page: number) {
  return withBasePath(page === 1 ? basePath : `${basePath}/${page}`);
}
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="Pagination">
    {currentPage > 1 && <a href={hrefFor(currentPage - 1)}>Previous</a>}
    <span class="pagination__status">
      Page {currentPage} of {totalPages}
    </span>
    {currentPage < totalPages && <a href={hrefFor(currentPage + 1)}>Next</a>}
  </nav>
)}

<style>
  .pagination {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: center;
    margin-top: var(--space-8);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .pagination a {
    text-decoration: none;
    padding: 0.7rem 0;
    font-family: var(--font-display);
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .pagination a:hover,
  .pagination a:focus-visible {
    color: var(--color-accent-strong);
    transform: translateY(-1px);
  }

  .pagination__status {
    font-family: var(--font-display);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-soft);
  }
</style>
