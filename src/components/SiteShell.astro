---
import instanceConfig from "../../instance.config.mjs";
import "@/styles/global.css";
import SeoHead from "@/components/SeoHead.astro";
import Analytics from "@/components/Analytics.astro";
import FontProviderHead from "@/components/FontProviderHead.astro";
import { withBasePath } from "@/lib/site";

interface Props {
  pageTitle: string;
  description: string;
  canonicalUrl: string;
  currentPath: string;
  type?: "website" | "article";
  image?: string;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: string[];
  section?: string;
  schema?: unknown[];
}

const {
  pageTitle,
  description,
  canonicalUrl,
  currentPath,
  type,
  image,
  publishedTime,
  modifiedTime,
  author,
  tags,
  section,
  schema = []
} = Astro.props;

const title = `${pageTitle} | ${instanceConfig.siteName}`;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <FontProviderHead />
    <SeoHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      currentPath={currentPath}
      type={type}
      image={image}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      tags={tags}
      section={section}
      schema={schema}
    />
  </head>
  <body>
    <Analytics />
    <header class="site-header">
      <div class="page-shell site-header__inner">
        <div class="site-header__topline">
          <span class="eyebrow">Independent Publishing System</span>
          <span class="site-header__description">{instanceConfig.siteDescription}</span>
        </div>
        <div class="site-header__masthead">
          <a class="site-header__name" href={withBasePath("/")}>{instanceConfig.siteName}</a>
          <p class="site-header__tagline">Editorial infrastructure for static publishing.</p>
        </div>
        <nav aria-label="Primary" class="site-nav">
          <ul>
            {instanceConfig.shell.navigation.map((item) => (
              <li>
                <a aria-current={currentPath === item.href ? "page" : undefined} href={withBasePath(item.href)}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <main data-pagefind-body>
      <slot />
    </main>
    <footer class="page-shell site-footer section-rule">
      <div>
        <p class="eyebrow">AstroNomer Edition</p>
        <p>{instanceConfig.siteDescription}</p>
      </div>
      <div>
        <p>
          Built as a static Astro instance with a host-shell seam through
          <code>SiteShell.astro</code>.
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background: transparent;
  }

  .site-header__inner {
    padding: var(--space-4) 0 var(--space-6);
  }

  .site-header__topline {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: center;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
  }

  .site-header__description {
    font-family: var(--font-display);
    font-size: 0.82rem;
    color: var(--color-text-soft);
  }

  .site-header__masthead {
    text-align: center;
    padding: var(--space-6) 0 var(--space-5);
    border-bottom: 1px solid var(--color-accent-strong);
  }

  .site-header__name {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: clamp(3.1rem, 9vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    text-decoration: none;
  }

  .site-header__name:hover,
  .site-header__name:focus-visible {
    transform: translateY(-1px);
  }

  .site-header__tagline {
    margin: 0.75rem 0 0;
    font-family: var(--font-display);
    font-size: 0.92rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-soft);
  }

  .site-nav ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    gap: var(--space-4);
  }

  .site-nav a {
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.85rem 0;
    border-bottom: 2px solid transparent;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    border-bottom-color: color-mix(in srgb, var(--color-accent-strong) 45%, transparent);
    transform: translateY(-1px);
  }

  .site-nav a[aria-current="page"] {
    border-bottom-color: var(--color-accent-strong);
  }

  .site-footer {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
    padding: var(--space-8) 0 var(--space-16);
    color: var(--color-text-soft);
  }

  @media (max-width: 720px) {
    .site-header__topline,
    .site-footer {
      grid-template-columns: 1fr;
      display: grid;
    }

    .site-header__topline {
      justify-content: start;
    }

    .site-header__description {
      display: none;
    }

    .site-nav ul {
      justify-content: start;
      gap: var(--space-3);
    }
  }
</style>
