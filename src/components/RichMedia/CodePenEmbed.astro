---
import ClickToLoadFrame from "@/components/RichMedia/ClickToLoadFrame.astro";

interface Props {
  user: string;
  pen: string;
  title?: string;
  defaultTab?: string;
  aspectRatio?: string;
}

const {
  user,
  pen,
  title = "CodePen embed",
  defaultTab = "result",
  aspectRatio = "4 / 3"
} = Astro.props;
---

<ClickToLoadFrame
  provider="CodePen"
  title={title}
  href={`https://codepen.io/${user}/pen/${pen}`}
  embedSrc={`https://codepen.io/${user}/embed/${pen}?default-tab=${defaultTab}&theme-id=light`}
  aspectRatio={aspectRatio}
  frameMaxWidth="52rem"
  revealLabel="View CodePen"
  targetBackground="#ffffff"
/>
