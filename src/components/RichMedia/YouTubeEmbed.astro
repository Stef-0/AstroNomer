---
import ClickToLoadFrame from "@/components/RichMedia/ClickToLoadFrame.astro";

interface Props {
  id: string;
  title?: string;
}

const { id, title = "YouTube video" } = Astro.props;
---

<ClickToLoadFrame
  provider="YouTube"
  title={title}
  href={`https://www.youtube.com/watch?v=${id}`}
  embedSrc={`https://www.youtube-nocookie.com/embed/${id}`}
  frameMaxWidth="56rem"
  revealLabel="View video"
/>
