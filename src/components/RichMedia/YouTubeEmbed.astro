---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div class="surface-card embed">
  <iframe
    src={`https://www.youtube-nocookie.com/embed/${id}`}
    title={title}
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>

<style>
  .embed {
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>

