---
import ClickToLoadFrame from "@/components/RichMedia/ClickToLoadFrame.astro";

interface Props {
  id: string;
  title: string;
  summary?: string;
}

const { id, title, summary } = Astro.props;
---

<ClickToLoadFrame
  provider="Vimeo"
  title={title}
  summary={summary}
  href={`https://vimeo.com/${id}`}
  embedSrc={`https://player.vimeo.com/video/${id}`}
/>

