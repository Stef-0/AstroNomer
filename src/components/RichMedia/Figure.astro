---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="surface-card figure">
  <img src={src} alt={alt} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure {
    padding: var(--space-3);
  }

  figcaption {
    padding: var(--space-3);
    color: var(--color-text-soft);
  }
</style>

