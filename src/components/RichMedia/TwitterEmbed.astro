---
import instanceConfig from "../../../instance.config.mjs";

interface Props {
  url: string;
}

const { url } = Astro.props;
const tweetId = url.match(/status\/(\d+)/)?.[1] ?? "";
const eager = instanceConfig.features.richMediaLoadStrategy === "eager";
---

{
  eager ? (
    <div class="tweet-card tweet-card--visible" data-tweet-root data-tweet-id={tweetId}>
      <div class="tweet-card__target"></div>
    </div>
  ) : (
    <div class="tweet-card" data-tweet-root data-tweet-id={tweetId}>
      <div class="tweet-card__target">
        <div class="tweet-card__veil">
          <div class="tweet-card__controls">
            <button type="button" class="tweet-card__button">View post</button>
            <a class="tweet-card__source-link" href={url} target="_blank" rel="noreferrer">Open source</a>
          </div>
        </div>
      </div>
      <p class="tweet-card__status" aria-live="polite"></p>
    </div>
  )
}

<script>
  const loadTwitterWidgets = () => {
    if (window.twttr?.widgets?.createTweet) {
      return Promise.resolve(window.twttr);
    }

    const existing = document.querySelector('script[data-twitter-widgets="true"]');
    if (existing) {
      return new Promise((resolve, reject) => {
        existing.addEventListener("load", () => resolve(window.twttr), { once: true });
        existing.addEventListener("error", reject, { once: true });
      });
    }

    return new Promise((resolve, reject) => {
      const script = document.createElement("script");
      script.src = "https://platform.twitter.com/widgets.js";
      script.async = true;
      script.defer = true;
      script.setAttribute("data-twitter-widgets", "true");
      script.addEventListener("load", () => resolve(window.twttr), { once: true });
      script.addEventListener("error", reject, { once: true });
      document.head.appendChild(script);
    });
  };

  const revealTweet = async (root) => {
    const tweetId = root.getAttribute("data-tweet-id");
    const target = root.querySelector(".tweet-card__target");
    const veil = root.querySelector(".tweet-card__veil");
    const status = root.querySelector(".tweet-card__status");

    if (!tweetId || !target) {
      if (status) status.textContent = "The post could not be loaded. Use the source link instead.";
      return;
    }

    try {
      const twttr = await loadTwitterWidgets();
      target.innerHTML = "";
      const slot = document.createElement("div");
      target.appendChild(slot);
      await twttr.widgets.createTweet(tweetId, slot, {
        dnt: true,
        align: "left",
        theme: "light"
      });

      if (veil) {
        target.appendChild(veil);
        requestAnimationFrame(() => {
          root.classList.add("is-loaded");
        });
        window.setTimeout(() => {
          veil.remove();
        }, 260);
      }

      if (status) status.textContent = "Loaded X / Twitter post.";
    } catch (error) {
      if (status) status.textContent = "The post could not be loaded. Use the source link instead.";
    }
  };

  document.querySelectorAll("[data-tweet-root]").forEach((root) => {
    if (root.dataset.bound === "true") return;
    root.dataset.bound = "true";

    if (root.classList.contains("tweet-card--visible")) {
      revealTweet(root);
      return;
    }

    root.querySelector(".tweet-card__button")?.addEventListener("click", () => {
      revealTweet(root);
    });
  });
</script>

<style>
  .tweet-card {
    display: block;
    width: auto;
    max-width: 100%;
  }

  .tweet-card__button,
  .tweet-card__source-link {
    border-radius: 999px;
    padding: 0.7rem 1rem;
    text-decoration: none;
  }

  .tweet-card__button {
    border: 0;
    background: var(--color-accent);
    color: white;
    cursor: pointer;
  }

  .tweet-card__source-link {
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: color-mix(in srgb, white 74%, transparent);
  }

  .tweet-card__status {
    min-height: 1.5rem;
    color: var(--color-text-soft);
    margin: var(--space-3) 0 0;
  }

  .tweet-card__target {
    position: relative;
    display: inline-block;
    width: min(100%, 34rem);
    max-width: 34rem;
    min-height: 28rem;
    border: 1px solid color-mix(in srgb, var(--color-border) 92%, transparent);
  }

  .tweet-card__veil {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: var(--space-6);
    background:
      linear-gradient(180deg, color-mix(in srgb, white 34%, transparent) 0%, color-mix(in srgb, var(--color-surface) 54%, transparent) 100%),
      radial-gradient(circle at 22% 24%, color-mix(in srgb, var(--color-highlight) 16%, transparent) 0, transparent 30%),
      radial-gradient(circle at 78% 70%, color-mix(in srgb, var(--color-border-strong) 10%, transparent) 0, transparent 34%);
    backdrop-filter: blur(18px) saturate(0.92);
    -webkit-backdrop-filter: blur(18px) saturate(0.92);
    transition: opacity 220ms ease;
  }

  .tweet-card__controls {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    width: min(100%, 24rem);
  }

  .tweet-card.is-loaded .tweet-card__veil {
    opacity: 0;
    pointer-events: none;
  }

  .tweet-card.is-loaded .tweet-card__target {
    width: fit-content;
    min-height: 0;
    max-width: 100%;
    border: 0;
  }

  .tweet-card :global(.twitter-tweet),
  .tweet-card :global(iframe.twitter-tweet-rendered) {
    margin: 0 !important;
  }
</style>
